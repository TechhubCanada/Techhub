{
  "name": "@techhub/medusa",
  "version": "2.0.0",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "seed:techhub": "medusa exec ./src/scripts/seed-techhub-products.ts",
    "start": "test -f .medusa/server/public/admin/index.html && cd .medusa/server && medusa start --host ${HOST:-0.0.0.0} --port ${PORT:-9000}",
    "dev": "medusa develop",
    "emails:dev": "email dev --dir=src/modules/resend/emails",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit"
  },
  "dependencies": {
    "@agilo/medusa-analytics-plugin": "^1.4.0",
    "@alphabite/medusa-collection-images": "^0.3.7",
    "@alphabite/medusa-wishlist": "^0.7.4",
    "@empty-complete-org/medusa-product-attributes": "^1.2.0",
    "@medusajs/admin-sdk": "2.17.2",
    "@medusajs/cli": "2.17.2",
    "@medusajs/framework": "2.17.2",
    "@medusajs/icons": "2.17.2",
    "@medusajs/medusa": "2.17.2",
    "@medusajs/types": "2.17.2",
    "@medusajs/ui": "4.1.19",
    "@react-email/components": "^1.0.7",
    "@tanstack/react-query": "5.64.2",
    "@weareseeed/medusa-square-plugin": "^0.0.30",
    "@webbers/invoices-medusa": "^1.0.6",
    "medusa-plugin-content": "^0.2.2",
    "meilisearch": "0.55.0",
    "posthog-node": "^5.24.15",
    "react-dropzone": "^15.0.0",
    "react-router": "6.30.4",
    "react-router-dom": "6.30.4",
    "resend": "^6.9.2"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.17.2",
    "@react-email/preview-server": "^5.2.8",
    "@swc/core": "^1.15.11",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.11",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jest": "^29.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-email": "5.2.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22 <25"
  },
  "packageManager": "pnpm@10.32.1"
}
